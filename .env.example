# Environment Configuration Example
# Copy this file to .env and fill in actual values

# Tracker URL for peer server announcements
TRACKER_URL=http://localhost:4000

# Tracker Port
TRACKER_PORT=4000

# Peer Port
PEER_PORT=3000

# Domain configuration
DOMAIN=pubweb.online

# Enable HTTPS (true/false)
ENABLE_HTTPS=false

# Node environment
NODE_ENV=production