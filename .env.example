# Environment Configuration Example
# Copy this file to .env and fill in actual values

# Tracker URL for peer server announcements
TRACKER_URL=http://localhost:4000

# Tracker Port
TRACKER_PORT=4000

# Peer Port
PEER_PORT=3000

# Domain configuration
DOMAIN=pubweb.online

# Enable HTTPS (true/false)
ENABLE_HTTPS=false

# Node environment
NODE_ENV=production

# Public host/IP or tunnel hostname reachable by tracker/gateway
PUBLIC_HOST=localhost

# Optional public base URL for status/share links
PUBLIC_BASE_URL=https://pubweb.online/page/

# Optional tunnel host alias (fallback for PUBLIC_HOST)
TUNNEL_HOST=

# Tracker persistent sqlite path
TRACKER_DB_PATH=./tracker.db

# Assignment replication target (coordinator)
REPLICATION_TARGET=2

# Peer contribution caps
PEER_MAX_DISK_BYTES=5368709120
PEER_MAX_UPLOAD_KBPS=2048

# NAT descriptor (optional telemetry)
NAT_TYPE=unknown