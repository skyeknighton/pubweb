{
  "name": "pubweb",
  "version": "0.10.6",
  "main": "dist/main/main/index.js",
  "description": "PubWeb - Decentralized webpage hosting with P2P distribution",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "electron-dev src/main/index.js",
    "dev:renderer": "webpack serve --config webpack.dev.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json",
    "build:renderer": "webpack --config webpack.prod.js",
    "start": "node start-service.js",
    "start:electron": "electron dist/main/main/index.js",
    "start:peer": "node start-peer.js",
    "publish:exemplar": "node publish-exemplar-page.js",
    "publish:make-page": "node publish-make-your-own-page.js",
    "publish:moby-dick": "node publish-moby-dick.js",
    "tracker": "node dist/main/tracker/index.js",
    "smoke": "node smoke-test-network.js",
    "smoke:railway": "node smoke-test-network.js --label railway",
    "wait:railway": "node wait-for-railway-ready.js",
    "smoke:railway:auto": "npm run wait:railway && npm run smoke:railway",
    "purge:smoke": "node purge-smoke-pages.js --dry-run",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "dist:win:local": "npm run build && electron-builder --win nsis portable --publish never --config.win.signAndEditExecutable=false",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "got": "^13.0.0",
    "nat-api": "^0.3.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "concurrently": "^8.0.1",
    "css-loader": "^6.8.1",
    "electron": "^24.0.0",
    "electron-builder": "^24.13.3",
    "electron-dev": "^1.0.1",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.5.0",
    "style-loader": "^3.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.2",
    "typescript": "^5.0.2",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.13.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "online.pubweb.app",
    "productName": "PubWeb",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "package.json",
      "start-peer.js",
      "start-service.js"
    ],
    "extraMetadata": {
      "main": "dist/main/main/index.js"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "skyeknighton",
        "repo": "pubweb"
      }
    ]
  }
}
